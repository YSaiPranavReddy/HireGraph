# ── LLM: Groq (JD Parser + Resume Screener — fast, parallel) ─────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── LLM: Google Gemini (Ranker + Bias Checker + Outreach Drafter) ────────────
# Get your free key at: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# ── LangSmith observability (optional) ───────────────────────────────────────
# Get your key at: https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=HireGraph

# ── Clerk ────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
FRONTEND_API_URL=https://your-clerk-domain.clerk.accounts.dev
